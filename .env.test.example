# =============================================================================
# Integration test environment (for `npm run test:integration`).
#
# These point the test suite at a LOCAL Supabase stack. Start one with:
#   supabase start
# then copy the printed values below. NEVER point these at production.
# =============================================================================

# Required to enable the integration suite (otherwise it self-skips):
NUDGET_DB_TEST="1"

# From `supabase start` output (API URL + keys):
SUPABASE_TEST_URL="http://127.0.0.1:54321"
SUPABASE_TEST_ANON_KEY="your-local-anon-key"
SUPABASE_TEST_SERVICE_ROLE_KEY="your-local-service-role-key"

# Optional — a throwaway 32-byte key for token-encryption round-trips.
# Defaults to a fixed test key if unset.
# TOKEN_ENCRYPTION_KEY="<64 hex chars>"
