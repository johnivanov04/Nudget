{
  "name": "nudget",
  "version": "0.1.0",
  "private": true,
  "description": "Nudget — iOS-first paycheck runway widget backend. Answers: \"Am I safe to spend before payday?\"",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:schema": "cat supabase/migrations/0001_init.sql supabase/migrations/0002_recurring_bill_merchant_key.sql supabase/migrations/0003_notifications.sql supabase/migrations/0004_morning_minute.sql supabase/migrations/0005_device_token_encrypted.sql",
    "verify:live": "bash scripts/verify-live.sh",
    "seed:demo": "bash scripts/seed-demo-user.sh",
    "demo:runway": "NUDGET_DEMO=1 vitest run src/scripts/demoRunway.test.ts --reporter=basic"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.64.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "15.5.19",
    "plaid": "^42.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "vitest": "3.2.6"
  }
}
