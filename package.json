{
  "name": "nudget",
  "version": "0.1.0",
  "private": true,
  "description": "Nudget — iOS-first paycheck runway widget backend. Answers: \"Am I safe to spend before payday?\"",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "demo:runway": "NUDGET_DEMO=1 vitest run src/scripts/demoRunway.test.ts --reporter=basic"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.48.1",
    "next": "15.1.6",
    "plaid": "^42.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "8.57.1",
    "eslint-config-next": "15.1.6",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
